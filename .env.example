# Supabase — completar con valores reales en .env.local (no commitear)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solo en servidor. Mantener fuera del cliente.
SUPABASE_SERVICE_ROLE_KEY=

# Reset de contraseña por email para jugadores (Bug 3 / Fase C).
# El jugador tiene auth.email sintético (no recibe mails); el link de recovery
# se le manda a su email real vía la API de Resend. Sin estas vars, el reset
# self-service del jugador no envía (cae en log server-side, sin romper la UI).
#   RESEND_API_KEY: API key de Resend (re_...).
#   RESEND_FROM: remitente verificado en Resend, ej.
#     "Fútbol de los martes <no-reply@tudominio.com>".
RESEND_API_KEY=
RESEND_FROM=

# Linear (solo para correr scripts/seed-linear.ts). Personal API key.
# Generar en: Linear -> Settings -> API -> Personal API keys -> Create key.
LINEAR_API_KEY=
