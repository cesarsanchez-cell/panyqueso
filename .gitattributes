# Normalizar line endings: LF en el repo, indep del SO del dev.
# Evita que Prettier marque archivos como mal formateados en CI tras un commit
# desde Windows con CRLF.
* text=auto eol=lf

# Scripts Windows-nativos: mantener CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binarios: que git no toque.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
